pipeline {
   agent {
        node {
            label 'built-in'
        }
    }
    triggers {
        cron('0 2 * * *')  // 每天凌晨2点触发
    }
    environment {
        PATH = "/host-bin:${env.PATH}"
        MYSQL_PASSWORD = credentials('mysql-root-password')
    }
    stages {
        stage('Backup MySQL') {
            steps {
                script {
                    sh '''
                        podname=$(kubectl get pods -n sock-shop -l name=catalogue-db -o jsonpath='{.items[0].metadata.name}')
                        echo $podname
                        kubectl exec -n sock-shop $podname -- \
                        mysqldump -uroot -p$MYSQL_PASSWORD_PSW --all-databases --single-transaction 2>/dev/null > catalogue-db-backup.sql
                    '''
                }
            }
        }
        stage('Backup MongoDB') {
            steps {
                script {
                    sh '''
                        kubectl exec -n sock-shop $(kubectl get pods -n sock-shop -l name=carts-db -o jsonpath='{.items[0].metadata.name}') -- \
                        mongodump --archive > carts-db-backup.archive
                    '''
                }
            }
        }
        stage('Archive Backups') {
            steps {
                archiveArtifacts artifacts: '*.sql,*.archive'
            }
        }
    }
}
